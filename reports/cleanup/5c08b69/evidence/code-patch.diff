+
+  useEffect(() => {
+    if (!id) return;
+
+    const fetchProject = async () => {
+      setLoading(true);
+      setError(null);
+      try {
+        const data = await httpClient<{ data: Project[] }>(`/api/projects/${id}`);
+        if (data.data && data.data.length > 0) {
+          setProject(data.data[0]);
+        } else {
