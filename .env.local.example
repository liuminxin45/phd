PHA_HOST=http://pha.example.com
PHA_TOKEN=api-xxxxxxxxxxxxxxxx

# For unstandard data API (session-based auth)
# These will be auto-updated by: npm run refresh-session
PHA_USER=your_username
PHA_SESSION=your_session_id

# Login credentials for auto-refresh session
PHA_LOGIN_USER=your_email@tp-link.com.cn
PHA_LOGIN_PASS=your_password

# Dinner subsidy system (optional, falls back to PHA_LOGIN_* if not set)
# DINNER_LOGIN_USER=your_email@tp-link.com.cn
# DINNER_LOGIN_PASS=your_password
# DINNER_SESSION will be auto-updated when logging in
